    <modelVersion>4.0.0</modelVersion>

    <artifactId>cosh-spring</artifactId>
    <name>COSH Spring</name>
    <description>
        COSH Spring Boot Starter (Phase 5).
        Auto-configures a CoshCache bean.
        Supports @CoshCacheable(ttl=60) annotation via AOP.
